###
@authToken = {{login.response.body.data.token}}
GET http://localhost:5000/api/users
Authorization: Bearer {{authToken}}

###
@authToken = {{login.response.body.data.token}}
POST http://localhost:5000/api/users
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "ahmed",
  "email": "ahmed@xyz.com",
  "password": 123456
}
